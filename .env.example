# ---------------------------------------------------------------------------
# Optional overrides for Arth (local-first personal finance).
#
# Most secrets live in the dashboard (Settings + onboarding). Keep this file for:
#   • CI / automation (dummy keys are fine)
#   • advanced knobs (custom DB path, CORS, Gmail OAuth port)
# Copy to ".env" at the repo root; never commit ".env".
# ---------------------------------------------------------------------------

# ── Logging ───────────────────────────────────────────────────────────────────
# How chatty the terminal is (stdout). The log file always keeps DEBUG+.
# Use DEBUG when you need full traces on the console while troubleshooting.
ARTH_LOG_LEVEL=INFO

# ── CI / optional legacy classifier env keys ─────────────────────────────────
# OPENAI_API_KEY=dummy
# ANTHROPIC_API_KEY=dummy
# GOOGLE_API_KEY=dummy

# Classification pipeline (optional if keys are saved in the dashboard UI).
# OPENAI_API_KEY_FOR_CLASSIFIER=
# ANTHROPIC_API_KEY_FOR_CLASSIFIER=
# GOOGLE_API_KEY_FOR_CLASSIFIER=
LLM_MODEL=auto

# ── Agent CLI / optional server-side agent keys ────────────────────────────────
# Prefer storing agent keys in Settings (encrypted SQLite). Use these for Docker-only setups.
# OPENAI_API_KEY_FOR_SINGLE_AGENT=
# Optional moderation-only OpenAI key (Layer-1 screening). See scripts/check_moderation_key.py.
# OPENAI_API_KEY_FOR_MODERATION=
# ANTHROPIC_API_KEY_FOR_SINGLE_AGENT=
# GOOGLE_API_KEY_FOR_SINGLE_AGENT=
# AGENT_MODEL=gemini/gemini-3-flash-preview
# AGENT_FALLBACK_CHAIN=gemini/gemini-3-flash-preview,anthropic/claude-sonnet-4-6

# ── Optional signing key for session cookies / WS tickets ────────────────────
# If unset, each API process generates an ephemeral key (cookies reset on restart).
# AUTH_SECRET_KEY=

# ── SQLite ─────────────────────────────────────────────────────────────────────
# ARTH_DB_PATH=/path/to/arth_main.db

# ── Gmail OAuth callback (desktop flow; dashboard opens Google in-browser) ─────
# The repo ships data/gmail_credentials.json (shared installed OAuth client). Replace
# it only if you use your own Google Cloud project (each user still gets their own token).
# Publish this port from Docker so Google can redirect back to your laptop.
# ARTH_GMAIL_OAUTH_CALLBACK_PORT=8090
# ARTH_GMAIL_OAUTH_BIND_HOST=0.0.0.0
# ARTH_GMAIL_OAUTH_REDIRECT_HOST=127.0.0.1

# ── Scraper timing (defaults exist in code: 15 min / 7 days) ───────────────────
# SCRAPER_POLL_INTERVAL_MINUTES=15
# SCRAPER_LOOKBACK_DAYS=7

# ── CORS (when dashboard hostname ≠ localhost) ───────────────────────────────
# CORS_EXTRA_ORIGINS=https://your-host.example.com

# ── Inflation fetch (offline tests) ────────────────────────────────────────────
# INFLATION_DISABLE_IMF=1

# ── Holdings encryption / PDF unlock / DOB (optional if not using dashboard) ───
# FERNET_KEY=
# PDF_DECRYPT_PASSWORD=
# DOB=
# HDFC_STATEMENT_PASSWORD=
