# Optional legacy fallbacks (e.g. CI sets OPENAI_API_KEY=dummy). ``pipeline/config.py`` reads
# *_FOR_CLASSIFIER first, then OPENAI_API_KEY / ANTHROPIC_API_KEY / GOOGLE_API_KEY.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# LLM API keys — **classification pipeline** (transaction LLM classify in ``pipeline/``).
# Use dedicated keys so provider dashboards show spend separately from the conversational agent.
OPENAI_API_KEY_FOR_CLASSIFIER=sk-...
ANTHROPIC_API_KEY_FOR_CLASSIFIER=sk-ant-...
GOOGLE_API_KEY_FOR_CLASSIFIER=AI...

# Which LLM model to use for classification.
# "auto" = multi-model fallback chain (recommended)
# "none" = rules-only, no LLM
# Or a specific model key: gemini-3.1-flash-lite, gemini-2.5-flash,
#   claude-haiku-4-5, claude-sonnet-4-6, claude-opus-4-6, gpt-5-mini, gpt-5-nano, etc.
LLM_MODEL=auto

# ── Gmail scraper (Phase 4) ────────────────────────────────────────────────────
# Path to the OAuth2 credentials file downloaded from Google Cloud Console.
# One-time setup: GCP project → enable Gmail API → create OAuth Desktop App
# credentials → download JSON → save as this path.
GMAIL_CREDENTIALS_PATH=data/gmail_credentials.json

# Path where the OAuth token is saved after first-run browser consent.
# Auto-refreshed on subsequent runs — you never need to re-authenticate.
GMAIL_TOKEN_PATH=data/gmail_token.json

# How often the background scheduler polls Gmail for new emails (minutes).
SCRAPER_POLL_INTERVAL_MINUTES=15

# On the very first run, how many days back to look for emails to backfill.
SCRAPER_LOOKBACK_DAYS=7

# ── Phase A.0 — asset / holdings encryption ───────────────────────────────────
# Fernet key (url-safe base64). Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If unset, the API may generate one and append it to .env on first use — back it up; loss = unreadable encrypted columns.
FERNET_KEY=

# Password for encrypted personal PDFs (e.g. term insurance). Never commit the real value.
PDF_DECRYPT_PASSWORD=

#Date of Birth (for NPS computations)
DOB=

# ── Statement PDFs from email (Phase 0 — email statement parsers) ─────────────
# Bank-emailed statements are password-protected PDFs. Used by
# scraper/pdf_utils.decrypt_pdf and the statement email parsers — not committed.
HDFC_STATEMENT_PASSWORD=
HDFC_CC_STATEMENT_PASSWORD=
# ICICI savings — monthly vs annual use different PDF passwords (and different subjects).
# Annual statement email: From customernotification@icicibank.com, subject starts "Bank Statement from …"
ICICI_STATEMENT_MONTHLY_PASSWORD=
ICICI_STATEMENT_ANNUAL_PASSWORD=
# ICICI Direct / demat: two passwords — ICICI-originated emails vs NSE “trades executed” email.
ICICI_DIRECT_EMAIL_PASSWORD=
NSE_TRADES_EXECUTED_PASSWORD=

# ── Holdings UI: NPS normal exit + illustrative projection ────────────────────
# Date of birth for the primary subscriber (YYYY-MM-DD). FastAPI loads this from the
# *root* .env — duplicate here if you run the API from the repo root. The dashboard
# .env.local is not read by Python; copying DOB there alone will not affect /api/holdings.
DOB=
# Optional nominal annual % for the NPS illustration (default 10). Try 11 or 12 if you want a more aggressive scenario.
# NPS_PROJECTION_ANNUAL_RATE_PCT=10

# ── Goals architecture — India CPI via IMF SDMX (Sub-Plan F) ─────────────────
# No API key. Live fetch uses sdmx1 + IMF_DATA (monthly index → YoY % for CPI_GENERAL).
# Set to 1 to skip network (tests / offline): INFLATION_DISABLE_IMF=1
# Index fetch start year (default 2018) — must be ≥12 months before first stored YoY month (2019-01).
# INFLATION_DISABLE_IMF=
# IMF_CPI_START_PERIOD=
# EMA span for goal decomposition (default 12; α = 2/(span+1)): INFLATION_SIMULATION_EMA_SPAN=6
# INFLATION_SIMULATION_EMA_SPAN=

# ── API + dashboard auth (FastAPI) ────────────────────────────────────────────
# Required for POST /api/auth/login and for signed session cookies.
AUTH_USERNAME=
AUTH_PASSWORD=
# Secret for signing session cookies (generate: python -c "import secrets; print(secrets.token_hex(32))")
AUTH_SECRET_KEY=

# ── Arth conversational agent (CLI: python -m agent.cli) ──────────────────────
# Same repo-root .env as everything else — there is no agent/.env. Run the CLI from
# the repo root (or set DOTENV_PATH) so python-dotenv finds this file.
#
# **Separate keys** from classification — ``agent/llm.py`` passes these explicitly to LiteLLM
# (it does not fall back to OPENAI_API_KEY_FOR_CLASSIFIER or legacy names).
OPENAI_API_KEY_FOR_SINGLE_AGENT=sk-...
ANTHROPIC_API_KEY_FOR_SINGLE_AGENT=sk-ant-...
GOOGLE_API_KEY_FOR_SINGLE_AGENT=AI...

# Primary LiteLLM model id (provider/model). Default: Gemini 3 Flash preview.
# AGENT_MODEL=gemini/gemini-3-flash-preview

# Comma-separated fallbacks if the primary errors or times out.
# AGENT_FALLBACK_CHAIN=gemini/gemini-3-flash-preview,anthropic/claude-sonnet-4-6,openai/gpt-5-mini-2025-08-07

# Google recommends 1.0 for Gemini 3; leave unset to use the default in code.
# AGENT_TEMPERATURE=1.0

# Max completion tokens per LLM response (default 24576 in code).
# MAX_OUTPUT_TOKENS=24576

# Cap tool batches per user message (default 10).
# MAX_TOOL_CALLS_PER_TURN=10

# Soft cap on stored chat messages (default 40); older messages are dropped from RAM.
# MAX_CONVERSATION_TURNS=40

# Seconds per LLM HTTP call (default 120).
# LLM_REQUEST_TIMEOUT=120

# Optional: cheap model for future input screening (Plan 3); default in code if unset.
# SCREENING_MODEL=gemini/gemini-3.1-flash-lite-preview

# Gemini 3 thinking depth when AGENT_GEMINI_EXTRA_THINKING is true: high | medium | low | minimal
# AGENT_THINKING_LEVEL=high

# Send thinking_level to Google via LiteLLM extra_body (default false — enable only if your stack accepts it).
# AGENT_GEMINI_EXTRA_THINKING=false

# Optional: shared secret for X-Arth-Internal (in-process agent → API). If unset, a
# deterministic value is derived from AUTH_SECRET_KEY (see api.auth.agent_internal_token).
# AGENT_INTERNAL_TOKEN=

# CLI session transcripts (LLM steps, tool args/results, final reply) are written under
# agent/logs/session-*.log — ignored by git; open the path printed when the CLI starts.
