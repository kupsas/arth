# Ignore Cursor project metadata (use `.cursor` not `.cursor/` — symlinks are not “directories” for ignore rules)
.cursor

# Python virtual environments
.venv/
venv/
env/

# Python cache and build artifacts
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
.build/
build/
dist/
.eggs/
*.egg-info/

# Test and coverage artifacts
.pytest_cache/
.coverage*
coverage.xml
htmlcov/

# Environment secrets (API keys — never commit)
.env

# Security disclosure policy — maintain locally until we’re ready to publish it
SECURITY.md

# OS / editor files
.DS_Store
.idea/
.vscode/

# Personal goal pyramid seed (B.4) — household targets and IDs; keep local only
scripts/seed_goals.py

# Item C dev seed — real names / household PII; run locally only, never commit
scripts/seed_sashank_classification_dev.py

# Zerodha demat probe — local dev tool; contains a real PAN + personal email, keep local only
scripts/zerodha_demat_probe.py

# CI worktree scratch (per-PR checkout dirs + logs) — machine-local, never commit
.ci-worktrees/

# Personal financial data (do NOT commit)
# Note: this is a symlink to Arth/docs/personal-data — trailing slash won't match symlinks
docs/personal-data

# Private strategic documents (personal financial goals, amounts, planning).
# Ignore ``docs/private`` with and without trailing slash so the untracked
# symlink (git treats it as a file — ``docs/private/`` alone can miss it) is
# never accidentally added.
docs/private
docs/private/
docs/product/

# Generated benchmark CSVs — contain real transaction data (dates, amounts, narrations)
# Re-generate with: python3 scripts/export_benchmark.py
data/test/benchmark_*.csv

# Local AMFI/NAV demo extracts — not for version control
data/samples/

# Generated pipeline output and LLM cache
data/output/
data/.llm_cache/

# NSE package cache — bhav copies are public; nse_cookies_requests.json is session-like and must stay local
data/.nse_cache/

# Log files — keep the directory itself (via .gitkeep) but ignore log contents
data/logs/*.log
data/logs/*.log.*

# Agent CLI session transcripts (full ReAct traces)
agent/logs/*.log

# Agent eval run outputs (JSON + markdown reports — machine-local)
agent/evals/results/*
!agent/evals/results/.gitkeep

# SQLite backup files — large, machine-specific, never commit
data/backups/

# SQLite database files (real data — never commit)
data/*.db
# WAL mode creates these alongside the main .db file — machine-local, do not commit
data/*.db-wal
data/*.db-shm

# Manual / timestamped DB copies (e.g. arth.db.bak.YYYYMMDD_* and WAL/SHM siblings) — same sensitivity as *.db
# Prefer a single folder: copy DBs into data/backups/ (also ignored via data/backups/ below).
data/*bak*
data/*.bak
data/*backup*

# Learned ICICI broker code → NSE ticker (machine-local; grows over time)
data/icici_nse_symbol_overrides.json

# Optional NSE symbol → cap bucket overrides (copy from data/nse_market_cap.example.json)
data/nse_market_cap_overrides.json

# Gmail OAuth credentials and token (never commit — contains secrets)
# OAuth token only — never commit (contains refresh token).
data/gmail_token.json

# Local find/replace map used when syncing real Gmail HTML into fixtures (may contain PII substrings).
data/email_fixture_redactions.json

# Committed HTML under tests/fixtures/email_samples/ is synthetic / scrubbed for CI.
# After `scripts/sync_email_parser_fixtures.py` with --no-redact, re-review before commit.

# Local clones of external repos for study / comparison (never commit)
research/

# Next.js dashboard build artifacts and nested git repo
dashboard/node_modules/
dashboard/.next/
dashboard/.env*.local
# dashboard has its own git history — exclude it from the root repo
dashboard/.git/

